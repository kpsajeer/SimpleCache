{
    "name": "simple-cache/simple-cache",
    "description": "Reusable PHP Cache Component",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "cache",
        "caching",
        "php",
        "apcu",
        "file",
        "array",
        "performance"
    ],
    "homepage": "https://github.com/kpsajeer/SimpleCache",
    "support": {
        "issues": "https://github.com/kpsajeer/SimpleCache/issues",
        "source": "https://github.com/kpsajeer/SimpleCache"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "autoload": {
        "psr-4": {
            "SimpleCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Benchmarks\\": "benchmarks/src"
        }
    },
    "authors": [
        {
            "name": "Sajeer",
            "email": "sajeer@bolasintelli.co.in"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.2",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2"
    },
    "scripts": {
        "test": "phpunit",
        "fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "benchmark": "php benchmarks/run.php",
        "check": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
